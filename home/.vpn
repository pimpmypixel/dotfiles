# --- VPN Management via Bitwarden ---
vpn() {
    local VPN_ITEM_NAME="dtu-vpn"
    local VPN_SERVER="https://vpn.dtu.dk"
    local PID_FILE="/tmp/openconnect_vpn.pid"

    # Colors
    local RED='\033[1;31m'
    local GREEN='\033[1;32m'
    local YELLOW='\033[1;33m'
    local BLUE='\033[1;34m'
    local BOLD='\033[1m'
    local NC='\033[0m'

    case "$1" in
        start)
            if [[ -f $PID_FILE ]]; then
                echo -e "${YELLOW}VPN already running (PID: $(cat $PID_FILE)).${NC}"
                return 1
            fi

            # Bitwarden Unlock Logic
            if [[ -z "$BW_SESSION" ]]; then
                echo -e "${YELLOW}No session found. Unlocking Vault...${NC}"
                export BW_SESSION=$(bw unlock --raw)
            fi

            if ! bw status | grep -q "unlocked"; then
                echo -e "${RED}Error: Vault is locked.${NC}"
                return 1
            fi

            echo -e "${BLUE}🔑 Fetching credentials...${NC}"
            local USER=$(bw get username "$VPN_ITEM_NAME")
            local PASS=$(bw get password "$VPN_ITEM_NAME")
            local TOTP=$(bw get totp "$VPN_ITEM_NAME")

            echo -e "${GREEN}🚀 Launching OpenConnect...${NC}"
            printf "%s\n%s\n" "$PASS" "$TOTP" | \
            sudo openconnect "$VPN_SERVER" -u "$USER" --passwd-on-stdin --background --pid-file=$PID_FILE --useragent=AnyConnect

            echo -e "${GREEN}${BOLD}✔ VPN started.${NC}"
            ;;

        stop)
            if [[ -f $PID_FILE ]]; then
                local PID=$(cat $PID_FILE)
                echo -e "${YELLOW}Stopping VPN (PID: $PID)...${NC}"
                sudo kill -SIGINT "$PID"
                sudo rm "$PID_FILE"
                echo -e "${GREEN}✔ Connection closed.${NC}"
            else
                echo -e "${RED}No active VPN process found.${NC}"
            fi
            ;;

        status)
            if [[ -f $PID_FILE ]] && ps -p $(cat $PID_FILE) > /dev/null; then
                echo -e "Status: ${GREEN}${BOLD}RUNNING${NC}"
                echo -e "${BLUE}Interface Details:${NC}"
                ifconfig | grep -A 4 "utun" || echo "No utun interface detected."
            else
                echo -e "Status: ${RED}${BOLD}STOPPED${NC}"
                [[ -f $PID_FILE ]] && sudo rm $PID_FILE
            fi
            ;;

        *)
            echo -e "${BOLD}Usage:${NC} vpn {start|stop|status}"
            return 1
            ;;
    esac
}
